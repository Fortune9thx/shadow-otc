# ─── Chain ────────────────────────────────────────────────────────────────────
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
RITUAL_WS_URL=wss://rpc.ritualfoundation.org/ws
RITUAL_VERIFIER_URL=https://rpc.ritualfoundation.org/api/verify

# ─── Wallets ───────────────────────────────────────────────────────────────────
# Use DIFFERENT private keys for buyer, seller, and verifier in a real demo.
# For quick testing you can use the same key for all three.
BUYER_PRIVATE_KEY=0x...your_buyer_private_key...
SELLER_PRIVATE_KEY=0x...your_seller_private_key...
VERIFIER_PRIVATE_KEY=0x...your_verifier_private_key...

# ─── Deployed contract ────────────────────────────────────────────────────────
SHADOW_OTC_ADDRESS=0x...deployed_shadow_otc_address...

# ─── Deal parameters (buyer agent) ───────────────────────────────────────────
# URL the verifier will fetch on-chain (must return JSON with a count field)
# Demo (no auth needed): https://jsonplaceholder.typicode.com/todos/1
# Real X post: wrap Twitter v2 API via a lightweight proxy
VERIFY_URL=https://jsonplaceholder.typicode.com/todos/1

# JSON key to search for in the response body.
# jsonplaceholder returns: {"userId":1,"id":1,"title":"...","completed":false}
# So '"userId":' will find the number 1, and LIKES_TARGET=1 will pass.
CONTENT_KEY="userId":

# Minimum value that must be present (likesTarget)
LIKES_TARGET=1

# Amount to lock in escrow (in RITUAL, e.g. 0.01)
ESCROW_AMOUNT=0.01

# ─── Verifier agent config ────────────────────────────────────────────────────
# Deal ID to verify (set at runtime)
# DEAL_ID=1

# Max times the agent script itself retries (separate from contract maxRetries)
MAX_AGENT_RETRIES=5

# Milliseconds to wait between retry attempts
RETRY_DELAY_MS=15000
